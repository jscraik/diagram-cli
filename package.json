{
  "name": "@brainwav/diagram",
  "version": "1.0.8",
  "description": "Generate architecture diagrams from codebases",
  "main": "src/diagram.js",
  "bin": {
    "diagram": "src/diagram.js"
  },
  "scripts": {
    "test": "mocha",
    "test:watch": "mocha --watch",
    "test:deep": "node scripts/deep-regression.js",
    "ci:artifacts": "mkdir -p .diagram && node src/diagram.js all . --output-dir .diagram && node src/diagram.js test . --format junit --output .diagram/architecture-results.xml",
    "prepublishOnly": "npm test",
    "release:prepare": "bash scripts/release-npm.sh",
    "release:prepare:initial": "bash scripts/release-npm.sh --initial",
    "release:publish": "bash scripts/release-npm.sh --publish",
    "release:publish:initial": "bash scripts/release-npm.sh --publish --initial",
    "harness": "node node_modules/@brainwav/coding-harness/dist/cli.js",
    "harness:pr-gates": "bash scripts/harness-pr-gates.sh",
    "postinstall": "simple-git-hooks",
    "harness:check": "bash scripts/harness-check.sh"
  },
  "keywords": [
    "diagrams",
    "mermaid",
    "architecture",
    "code-analysis",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@brainwav/coding-harness": "^0.6.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/request-error": "^7.1.0",
    "@octokit/rest": "^22.0.1",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "glob": "^10.0.0",
    "picomatch": "^4.0.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jscraik/diagram-cli.git"
  },
  "bugs": {
    "url": "https://github.com/jscraik/diagram-cli/issues"
  },
  "homepage": "https://github.com/jscraik/diagram-cli#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "src/diagram.js",
    "src/video.js",
    "src/utils/commands.js",
    "README.md",
    "scripts/refresh-diagram-context.sh",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "mocha": "^11.3.0",
    "simple-git-hooks": "^2.13.1"
  },
  "overrides": {
    "chai": "^4.5.0",
    "serialize-javascript": "^7.0.0",
    "diff": "^8.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npm test",
    "commit-msg": "node scripts/validate-commit-msg.js $1",
    "pre-push": "npm run test:deep"
  }
}
